APP_NAME=Lekhya
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lekhya
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@lekhya.in"
MAIL_FROM_NAME="${APP_NAME}"

# GST Gateway (use 'mock' for development, set real GSP credentials for production)
GST_DRIVER=mock
GST_CLIENT_ID=
GST_CLIENT_SECRET=
GST_USERNAME=
GST_PASSWORD=
GST_API_BASE=
GST_EINVOICE_THRESHOLD_CRORE=5

# Supabase (for Seedha Bill Mode A connector)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Seedha Bill
SEEDHA_BILL_MODE=mock
SEEDHA_BILL_BASE_URL=https://api.seedhabill.com/v1

# AI / Local LLM
AI_DRIVER=ollama
AI_ENDPOINT=http://localhost:11434/api/generate
AI_MODEL=llama3.2
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.1
ANTHROPIC_API_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_MODE=mock
RAZORPAY_UPI_ID=

# WhatsApp Business (Meta Cloud API)
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ID=

# Prabhas SSO (Brief 1)
PRABHAS_SSO_SECRET=your-shared-secret-here
PRABHAS_ACCOUNTS_URL=https://accounts.prabhas.in
PRABHAS_SEEDHABILL_URL=https://prabhassaas.in/app/seedhabill/app.html
PRABHAS_LOGOUT_URL=https://accounts.prabhas.in/logout
