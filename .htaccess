Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Serve real static files from lekhya-app/public/ directly (css, js, images, favicon)
    RewriteCond %{DOCUMENT_ROOT}/lekhya-app/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ lekhya-app/public/$1 [L,QSA]

    # Serve real directories from lekhya-app/public/ directly
    RewriteCond %{DOCUMENT_ROOT}/lekhya-app/public%{REQUEST_URI} -d
    RewriteRule ^(.*)$ lekhya-app/public/$1/ [L,QSA]

    # Everything else → Laravel front controller
    RewriteRule ^(.*)$ lekhya-app/public/index.php [L,QSA]
</IfModule>
